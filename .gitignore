# ====================================================================
# Kanji Builder — .gitignore
# ====================================================================

# --- macOS / Windows OS ----------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Expo web export staging ----------------------------------------
# `npx expo export --platform web --output-dir dist-web` outputs here.
# The committed copy lives under docs/app/ (see docs/app/.nojekyll).
dist-web/

# --- Xcode / Swift ---------------------------------------------------
## User settings
xcuserdata/
*.xcuserstate
*.xcuserdatad/

## Build products
build/
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

## Swift Package Manager
.swiftpm/
.build/
Package.resolved

## CocoaPods (using only if introduced)
Pods/

## Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

## Playgrounds
timeline.xctimeline
playground.xcworkspace

# --- Python (data pipeline) ------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# --- Node / Expo / React Native --------------------------------------
node_modules/

# Expo build/cache output
.expo/
web-build/
expo-env.d.ts

# Expo Router boilerplate (created by `npm run reset-project`)
app-example/

# Native folders generated by `expo prebuild` (we use EAS Build, so they
# should not be checked in unless we intentionally adopt the bare workflow)
/ios
/android

# Metro bundler
.metro-health-check*

# npm / yarn / pnpm
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.log*

# TypeScript incremental build info
*.tsbuildinfo

# RN / Android signing leftovers
.kotlin/
*.orig.*
*.jks

# --- Data sources & generated artifacts ------------------------------
# Raw source data (CC BY-SA 4.0 etc. — fetched by scripts at build time)
data/raw/
data/sources/
*.xml.gz
*.gz

# Generated bundle databases & assets
data/bundle/
*.sqlite
*.sqlite-shm
*.sqlite-wal

# EXCEPTION: the Metro-bundled copy of the kanji database is committed so
# EAS Build (which runs in a clean environment without Python + the raw
# KANJIDIC2/KRADFILE sources) can find the asset at build time. Local dev
# still regenerates it from `data/bundle/kanji.sqlite` via `npm run prepare-db`.
!assets/data/kanji.sqlite

# EXCEPTION: the Expo web export hashes its bundled assets and places them
# under docs/app/assets/{node_modules,assets}/. The `node_modules/` and
# `*.sqlite` rules above would otherwise swallow them. Negate the entire
# docs/app/assets/ subtree so GitHub Pages can serve the actual files.
!docs/app/assets/
!docs/app/assets/**

# KanjiVG SVGs (downloaded by pipeline)
data/strokes/
strokes/*.svg

# Tatoeba dumps
sentences.csv
sentences.tar.bz2

# --- Secrets / environment -------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.mobileprovision
AuthKey_*.p8

# --- IDE / editor ----------------------------------------------------
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# --- Logs & temp -----------------------------------------------------
*.log
logs/
tmp/
.tmp/
